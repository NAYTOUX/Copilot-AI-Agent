{
  "schema_version": 1,
  "hub_name": "universal-copilot-agent-hub",
  "version": "0.1.0",
  "status": "pre-release",
  "default_branch": "main",
  "default_entrypoint": "Universal Orchestrator",
  "generated_docs": [
    "docs/CAPABILITY_MATRIX.md",
    "docs/AGENT_CATALOG.md"
  ],
  "canonical_files": [
    "AGENTS.md",
    "README.md",
    ".github/copilot-instructions.md",
    ".vscode/settings.json",
    ".github/agent-registry.json",
    ".github/agent-relationship-map.json",
    ".github/routing-rules.json",
    ".github/evals/routing-cases.json",
    ".github/schemas/agent-report.schema.json",
    ".github/schemas/personality-spec.schema.json",
    ".github/personality-proposals/README.md",
    ".github/instructions/commit-message.instructions.md",
    ".github/instructions/copilot-code-review.instructions.md",
    ".github/instructions/pull-request-description.instructions.md",
    ".github/hooks/orchestrator-guardrails.json",
    ".github/ISSUE_TEMPLATE/agent-improvement.yml",
    ".github/ISSUE_TEMPLATE/routing-gap.yml",
    ".github/PULL_REQUEST_TEMPLATE.md",
    ".github/workflows/validate_copilot_customizations.yml",
    ".github/workflows/check_memory_append_only.yml",
    ".github/workflows/receive_agent_report.yml",
    ".github/workflows/refresh_orchestrator_profiles.yml",
    ".github/workflows/release_gate.yml",
    ".github/memory/MEMORY_INDEX.md",
    ".github/memory/agent-effectiveness-profile.md",
    ".github/memory/orchestrator-learning-profile.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "docs/ADOPTION_GUIDE.md",
    "docs/AGENT_RELATIONSHIPS.md",
    "docs/CHANGE_CONTROL.md",
    "docs/CROSS_REPO_USAGE_REPORTING.md",
    "docs/COPILOT_CODE_REVIEW.md",
    "docs/DECISION_RECORDS.md",
    "docs/DOWNSTREAM_REPORTING_KIT.md",
    "docs/MICROSOFT_COPILOT_ALIGNMENT.md",
    "docs/VS_CODE_COPILOT_SETTINGS.md",
    "docs/INFORMATION_RELAY.md",
    "docs/OWNERSHIP.md",
    "docs/PERSONALITY_EVOLUTION.md",
    "docs/PUBLISH_TO_GITHUB.md",
    "docs/RELEASE_PROCESS.md",
    "docs/ROUTING_ENGINE.md",
    "examples/agent-report.json",
    "examples/agent-feedback.json",
    "examples/orchestrator-usage-report.json",
    "examples/personality-spec.json"
  ],
  "required_commands": [
    "python .github/scripts/validate_copilot_customizations.py",
    "python .github/scripts/validate_json_contracts.py",
    "python .github/scripts/validate_agent_relationships.py",
    "python .github/scripts/scan_sensitive_content.py",
    "python .github/scripts/validate_agent_report_payload.py examples/agent-report.json",
    "python .github/scripts/validate_agent_report_payload.py examples/orchestrator-usage-report.json",
    "python .github/scripts/create_agent_personality.py --spec examples/personality-spec.json --dry-run",
    "python .github/scripts/promote_personality_proposal.py --proposal examples/personality-spec.json --allow-low-evidence",
    "python .github/scripts/report_orchestrator_usage.py --source-repo owner/repo --request \"Example request\" --selected-agents \"Universal Orchestrator,Memory Governor\"",
    "python .github/scripts/create_downstream_reporting_kit.py --target . --force",
    "python .github/scripts/copilot_hook_guard.py --event sessionStart",
    "python .github/scripts/evolve_personalities_from_memory.py",
    "python .github/scripts/update_agent_effectiveness_profile.py --check",
    "python .github/scripts/update_orchestrator_learning_profile.py --check",
    "python .github/scripts/maintain_memory_inbox.py",
    "python .github/scripts/generate_capability_matrix.py --check",
    "python .github/scripts/generate_agent_catalog.py --check",
    "python .github/scripts/audit_agent_hub.py",
    "python .github/scripts/evaluate_routing.py",
    "python .github/scripts/doctor_agent_hub.py --no-run",
    "python .github/scripts/check_memory_append_only.py",
    "python .github/scripts/run_orchestrator_checks.py",
    "python .github/scripts/prepare_release.py --allow-dirty --skip-checks"
  ],
  "release_gate": {
    "requires_clean_generated_docs": true,
    "requires_routing_eval": true,
    "requires_memory_append_only": true,
    "requires_sensitive_content_scan": true,
    "requires_no_audit_warnings": true,
    "requires_tests": true
  }
}
